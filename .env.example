# =============================================================================
# Video Ad Classifier — Environment Configuration
# Copy this file to .env and edit values before running.
# =============================================================================
#
# Topology notes
# --------------
# 1) Dashboard/UI:
#    - The frontend only talks to the API.
#    - Set VITE_API_BASE_URL to the API origin the dashboard should call.
#    - Vite is configured to read VITE_* variables from this repo-root .env.
#
# 2) API and workers on separate hosts:
#    - Supported today only in the shared-DB/shared-storage model.
#    - API host(s) and worker host(s) must all point to the SAME:
#        DATABASE_PATH
#        UPLOAD_DIR
#        ARTIFACTS_DIR
#    - Any server-side file paths submitted by users must be reachable from the
#      worker host that will process the job.
#    - There is no worker-over-HTTP control plane yet; workers claim from the DB.
#
# 3) Models on separate hosts:
#    - Supported today via OLLAMA_HOST and OPENAI_COMPAT_URL.
#    - Point those at the remote model host reachable from the API/worker host.
#
# 4) Clustered APIs:
#    - Configure API node URLs in CLUSTER_CONFIG.
#    - /cluster/jobs dedupes by job_id across nodes.
#
# Advanced options
# ----------------
# The bottom half of this file contains advanced tuning knobs.
# Leave them at defaults unless you are debugging, capacity-tuning, or working
# on OCR/fallback behavior. Changing them casually will change classification
# behavior and latency.


# =============================================================================
# Core topology and network endpoints
# =============================================================================

# Unique node name used as the job-id prefix and cluster identity.
NODE_NAME=node-a

# API bind host / port.
# - Honored by `python -m video_service.app.main`
# - Also read by Windows service scripts
# - If you launch uvicorn manually with --host/--port, those CLI flags win.
BIND_HOST=0.0.0.0
PORT=8000

# Dashboard -> API base URL.
# This is a frontend build/dev variable (Vite only exposes VITE_* variables).
# The dashboard does NOT talk to workers directly; point it at the API host.
# Example:
#   VITE_API_BASE_URL=http://api-host:8000
VITE_API_BASE_URL=http://localhost:8000

# Path to the JSON cluster node map.
# Leave unset for single-node mode.
# Example:
#   CLUSTER_CONFIG=cluster_config.json
#   nodes in that JSON should use API URLs, not worker URLs.
#CLUSTER_CONFIG=cluster_config.json

# Remote model hosts.
# Leave as localhost when the model runs on the same host as the worker.
OLLAMA_HOST=http://localhost:11434
OPENAI_COMPAT_URL=http://localhost:1234/v1/chat/completions


# =============================================================================
# Shared state and storage
# =============================================================================

# SQLite database path.
# Single-node default is a local DB file.
# For split API/worker deployments, this must point to a path visible to all
# participating hosts (for example a shared filesystem mount).
# Use an absolute path in production and Windows services.
DATABASE_PATH=video_service.db

# SQLite connection tuning.
SQLITE_TIMEOUT_SECONDS=30
SQLITE_BUSY_TIMEOUT_MS=30000

# Upload staging directory for files uploaded through the API.
# Must be shared with workers if workers are remote.
# Use an absolute path in production.
# Windows example: D:\\AdClassifier\\storage\\uploads
# POSIX example:   /srv/ad-classifier/storage/uploads
UPLOAD_DIR=storage/uploads

# Persistent per-job artifacts directory.
# Must be shared with workers if workers are remote.
# Use an absolute path in production.
# Windows example: D:\\AdClassifier\\storage\\artifacts
# POSIX example:   /srv/ad-classifier/storage/artifacts
ARTIFACTS_DIR=storage/artifacts

# Taxonomy CSV used to map category -> category_id.
# Default if unset: <repo>/video_service/data/categories.csv
# Windows example: D:\\AdClassifier\\video_service\\data\\categories.csv
# POSIX example:   /srv/ad-classifier/video_service/data/categories.csv
#CATEGORY_CSV_PATH=video_service/data/categories.csv


# =============================================================================
# API / worker role separation
# =============================================================================

# When true, the API process spawns embedded workers on startup.
# Set false when you want a pure API host and will run workers separately.
EMBED_WORKERS=true

# Number of standalone or embedded worker processes per host.
# This controls concurrent jobs per host, not threads inside one job.
WORKER_PROCESSES=1

# Threads used inside a single pipeline job.
# Keep at 1 on CPU/MPS unless you have profiled memory headroom.
PIPELINE_THREADS_PER_JOB=1


# =============================================================================
# Dashboard / browser access
# =============================================================================

# Comma-separated list of allowed dashboard origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174


# =============================================================================
# Logging and observability
# =============================================================================

# Python application log level.
LOG_LEVEL=INFO

# When true, also write rotating log files from the Python app itself.
# Default behavior remains stdout/stderr only.
LOG_TO_FILE=false

# Directory used for rotating runtime log files when LOG_TO_FILE=true.
# Relative paths are resolved from the repo root.
# Windows example: D:\\AdClassifier\\logs
# POSIX example:   /srv/ad-classifier/logs
LOG_DIR=logs

# Runtime log filename when LOG_TO_FILE=true.
LOG_FILENAME=video_service.log

# Rotating file log size/cycle settings.
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Maximum time to wait for a model/provider request before failing it.
LLM_TIMEOUT_SECONDS=60

# Validation-mode threshold for optional web-search confirmation of LLM results.
LLM_VALIDATION_THRESHOLD=0.7

# Guard against overconfident slogan-only brand matches.
# When enabled, the pipeline may run a narrow web confirmation step only if the
# guessed brand is weakly anchored (for example: slogan present but no exact
# brand token or domain in OCR).
BRAND_AMBIGUITY_GUARD=true
BRAND_AMBIGUITY_CONFIDENCE_THRESHOLD=0.85


# =============================================================================
# Device and model runtime
# =============================================================================

# Preferred torch device:
#   auto | cuda | mps | cpu
DEVICE_PREFERENCE=auto

# Preferred torch dtype:
#   auto | float16 | bfloat16 | float32
TORCH_DTYPE=auto

# Run a small torch self-test on startup and fall back to CPU if it fails.
# 0/empty disables; 1 enables.
ENABLE_DEVICE_SELFTEST=0

# CUDA device index when multiple CUDA GPUs exist.
CUDA_DEVICE_INDEX=0


# =============================================================================
# Security and path controls
# =============================================================================

# Maximum upload size accepted by /jobs/upload (MB).
MAX_UPLOAD_MB=5000

# Maximum size fetched from a remote URL before the download is rejected (MB).
URL_MAX_SIZE_MB=2048

# HTTP fetch timeout for remote video URLs (seconds).
URL_FETCH_TIMEOUT=30

# Optional hostname allowlist for /jobs/by-urls.
# Empty means allow all hosts except those denied below.
#URL_HOST_ALLOWLIST=mycompany.com,cdn.mycompany.com

# Optional hostname denylist for /jobs/by-urls.
#URL_HOST_DENYLIST=localhost,127.0.0.1

# Optional comma-separated list of server-side roots allowed for /jobs/by-folder.
# Empty means any absolute path is accepted.
#ALLOWED_FOLDER_ROOTS=/data/videos,/mnt/nas/ads


# =============================================================================
# Cleanup and stale-job recovery
# =============================================================================

# Enable background cleanup of old jobs/artifacts.
CLEANUP_ENABLED=true

# Delete completed/failed job rows older than this many days.
JOB_TTL_DAYS=30

# How often the cleanup task runs (hours).
CLEANUP_INTERVAL_HOURS=6

# Recover processing jobs that have gone stale longer than this many seconds.
# Set to 0 to disable the continuous watchdog (startup recovery still runs).
STALE_JOB_TIMEOUT_SECONDS=180

# How often stale-job recovery checks run (seconds).
STALE_JOB_CHECK_INTERVAL_SECONDS=120


# =============================================================================
# Watch-folder auto ingest
# =============================================================================

# Comma-separated directories to watch for new video files.
# Leave empty to disable the watcher.
WATCH_FOLDERS=

# Optional directory where watch-folder JSON result files are written.
WATCH_OUTPUT_DIR=

# Default watch-folder job mode:
#   pipeline | agent
WATCH_DEFAULT_MODE=pipeline

# Default watch-folder job settings.
WATCH_DEFAULT_PROVIDER=Ollama
WATCH_DEFAULT_MODEL=qwen3-vl:8b-instruct
WATCH_DEFAULT_OCR_ENGINE=EasyOCR
WATCH_DEFAULT_SCAN_MODE=Tail Only

# How long a file must remain size-stable before watch-folder ingest submits it.
WATCH_STABILIZE_SECONDS=3


# =============================================================================
# Benchmark UI / evaluation defaults
# =============================================================================

# Fallback Ollama model used by benchmark utilities when the model list is empty.
DEFAULT_MODEL=qwen3-vl:8b-instruct

# Fallback benchmark models used when the provider-specific model list endpoint
# cannot be reached.
BENCHMARK_LM_STUDIO_MODEL=local-model
BENCHMARK_LLAMA_SERVER_MODEL=local-model
BENCHMARK_GEMINI_MODEL=Gemini CLI Default


# =============================================================================
# Service / installer helpers
# =============================================================================

# Optional venv path used by some service installers (for example Windows NSSM).
# The Python runtime itself does not read this.
#VENV_PATH=.venv


# =============================================================================
# Advanced OCR and fallback tuning
# Leave these at defaults unless you are actively tuning classification behavior.
# =============================================================================

# --- Tail frame extraction ----------------------------------------------------

# Number of target frames in the default 3-second tail window.
TAIL_TARGET_FRAMES=5

# Histogram-correlation threshold used to decide the tail is visually static.
TAIL_STATIC_THRESHOLD=0.97

# Maximum backward walk in seconds once a static tail endcard is detected.
TAIL_MAX_BACKWARD_SECONDS=12


# --- OCR engine sizing --------------------------------------------------------

# Florence-2 generation token caps.
FLORENCE_MAX_NEW_TOKENS=1024
FLORENCE_MAX_NEW_TOKENS_FAST=256

# EasyOCR image downscaling caps.
# 0 means "do not resize" for that mode.
EASYOCR_MAX_DIMENSION_FAST=960
EASYOCR_MAX_DIMENSION_DETAILED=0


# --- OCR fast-path cleanup ----------------------------------------------------

# Jaccard similarity threshold for post-OCR text deduplication.
OCR_DEDUP_THRESHOLD=0.85

# Visual similarity threshold used before OCR to collapse near-identical frames.
OCR_FRAME_SIMILARITY_THRESHOLD=0.985

# When true, OCR first tries to locate a text-heavy region of interest.
OCR_ROI_FIRST=true

# When true, non-final frames with no plausible OCR ROI are skipped.
OCR_SKIP_NO_ROI_FRAMES=true

# Stop OCRing more frames once enough signal has already been captured.
OCR_EARLY_STOP_ENABLED=true
OCR_EARLY_STOP_MIN_CHARS=12


# --- OCR skip when multimodal evidence is already strong ---------------------

# Skip OCR completely on strong, visually explicit, static-tail cases.
OCR_SKIP_HIGH_CONFIDENCE=true
OCR_SKIP_CONFIDENCE_THRESHOLD=0.90
OCR_SKIP_VISION_SCORE_THRESHOLD=0.80
OCR_SKIP_MIN_BRIGHTNESS=20
OCR_SKIP_MIN_SHARPNESS=40


# --- Rescue ladder toggles ---------------------------------------------------

# First dark-tail / weak-tail rescue path.
OCR_EDGE_RESCUE_ENABLED=true

# Aggregate OCR context across multiple frames before escalating to heavier
# retries. Useful when the initial OCR is too sparse to be trustworthy.
OCR_CONTEXT_RESCUE_ENABLED=true

# Image-first rescue using a single branded/static frame and no OCR.
EXPRESS_RESCUE_ENABLED=true

# Rescue that scans further back in time than the default tail window.
OCR_EXTENDED_TAIL_RESCUE_ENABLED=true

# Last-resort sparse scan across the full video.
OCR_FULL_VIDEO_RESCUE_ENABLED=true


# --- First rescue-tail scan ---------------------------------------------------

# Initial rescue-tail sampling window and cadence.
OCR_RESCUE_TAIL_WINDOW_SECONDS=12
OCR_RESCUE_TAIL_STEP_SECONDS=1.0

# Frames darker than this brightness are skipped during rescue-tail sampling.
OCR_RESCUE_MIN_BRIGHTNESS=5.0


# --- OCR context rescue heuristics -------------------------------------------

# Trigger OCR-context rescue when OCR is short/sparse and confidence is below
# this level, or when mapper support is weak.
OCR_CONTEXT_CONFIDENCE_THRESHOLD=0.80
OCR_CONTEXT_SHORT_TEXT_CHARS=48
OCR_CONTEXT_SPARSE_TOKENS=6

# Maximum OCR lines / characters packed into the rescue prompt.
OCR_CONTEXT_MAX_LINES=8
OCR_CONTEXT_MAX_CHARS=600

# Optional vision assist for OCR-context rescue.
# Leave disabled unless you are explicitly tuning rescue behavior.
OCR_CONTEXT_USE_VISION_ASSIST=false
OCR_CONTEXT_VISION_SCORE_THRESHOLD=0.10
OCR_CONTEXT_VISION_MARGIN_THRESHOLD=0.03

# If the mapper score falls below this threshold, the OCR-context rescue can run
# even when the LLM itself appears confident.
OCR_CONTEXT_MAPPER_SCORE_THRESHOLD=0.82

# Minimum support score required before OCR text is treated as genuinely useful.
OCR_SUPPORT_SCORE_THRESHOLD=0.72


# --- Extended tail / full video rescue sizing --------------------------------

OCR_EXTENDED_TAIL_WINDOW_SECONDS=30
OCR_EXTENDED_TAIL_STEP_SECONDS=2.0
OCR_FULL_VIDEO_RESCUE_MAX_FRAMES=24


# --- Search-based specificity rescue -----------------------------------------

# When true and web search is enabled for the job, broad/generic categories can
# be refined into a more specific taxonomy leaf using retrieved evidence.
SPECIFICITY_SEARCH_RESCUE_ENABLED=true

# Trigger thresholds for search-based specificity rescue.
SPECIFICITY_SEARCH_MAPPER_SCORE_THRESHOLD=0.65
SPECIFICITY_SEARCH_VISION_SCORE_THRESHOLD=0.55

# Comma-separated mapped canonical categories treated as too broad and eligible
# for specificity rescue.
SPECIFICITY_SEARCH_BROAD_CATEGORIES=Financial Services,Retail,Technology,Educational,Banking,Insurance,Automotive,Telecommunications,Travel,Healthcare,Nonprofit Institutions

# Comma-separated raw LLM categories treated as generic and eligible for
# specificity rescue even if the mapped result already looks like a leaf.
SPECIFICITY_SEARCH_GENERIC_RAW_CATEGORIES=Movie,Film,Entertainment,Financial Services,Banking,Insurance,Retail,Technology,Educational,Healthcare,Travel,Automotive
